# ============================================
# ADAKAL GROUP - Variables d'environnement Odoo
# ============================================
# IMPORTANT : Modifiez ces valeurs AVANT le premier lancement !

# --- PostgreSQL / Patroni ---
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo_secure_password_2026
PATRONI_SUPERUSER_PASSWORD=postgres_super_2026
PATRONI_REPLICATION_PASSWORD=replicator_2026

# --- Odoo Ports ---
# Port principal Odoo (interface web)
ODOO_PORT=8069
# Port longpolling (live chat, notifications temps réel)
ODOO_LONGPOLLING_PORT=8072

# --- Stockage S3 Compatible ---
# IMPORTANT : Renseignez vos identifiants S3 ci-dessous
S3_ACCESS_KEY=votre_access_key_ici
S3_SECRET_KEY=votre_secret_key_ici
S3_BUCKET=adakal-odoo-filestore
S3_ENDPOINT=https://s3.votre-provider.com
S3_REGION=fr-par
