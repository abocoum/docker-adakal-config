# ============================================
# ADAKAL GROUP - Variables d'environnement Odoo
# ============================================
# NOTE : Les mots de passe sont gérés via Docker Secrets.
# Exécutez create-secrets.sh pour les créer.
# Ce fichier ne contient que les variables non-sensibles.

# --- Odoo Ports ---
# Port principal Odoo (interface web)
ODOO_PORT=8069
# Port longpolling (live chat, notifications temps réel)
ODOO_LONGPOLLING_PORT=8072

# --- Stockage S3 Compatible ---
S3_BUCKET=adakal-odoo-filestore
S3_ENDPOINT=https://s3.votre-provider.com
S3_REGION=fr-par
